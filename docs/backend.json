{
  "entities": {
    "CollegeInfo": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "CollegeInfo",
      "type": "object",
      "description": "Stores general information and configuration details for the college displayed in the application.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "logoUrl": { "type": "string", "format": "uri" },
        "tagline": { "type": "string" },
        "facilityOverview": { "type": "string" },
        "statisticalHighlights": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["id", "name", "logoUrl", "tagline", "facilityOverview", "statisticalHighlights"]
    },
    "Achievement": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Achievement",
      "type": "object",
      "description": "Represents an academic, research, or extracurricular achievement of the college or its students.",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "category": { "type": "string" },
        "year": { "type": "number" },
        "imageUrl": { "type": "string", "format": "uri" }
      },
      "required": ["id", "title", "description", "category", "year"]
    },
    "StudentProfile": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "StudentProfile",
      "type": "object",
      "description": "Stores detailed biographical and contact information for each student.",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "fullName": { "type": "string" },
        "gender": { "type": "string" },
        "phoneNumber": { "type": "string" },
        "address": { "type": "string" },
        "fatherName": { "type": "string" },
        "fatherPhoneNumber": { "type": "string" },
        "motherName": { "type": "string" },
        "motherPhoneNumber": { "type": "string" },
        "religion": { "type": "string" },
        "aadharNumber": { "type": "string" },
        "quota": { "type": "string", "enum": ["Government", "Management"] },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "userId", "fullName", "gender", "phoneNumber", "address", "fatherName", "motherName", "aadharNumber", "quota"]
    }
  },
  "auth": {
    "providers": ["password", "anonymous"]
  },
  "firestore": {
    "structure": [
      {
        "path": "/colleges/{collegeId}/users/{userId}",
        "definition": {
          "entityName": "InstitutionalUser",
          "description": "Directory of all institutional users including students, faculty, and admins."
        }
      },
      {
        "path": "/colleges/{collegeId}/studentProfiles/{userId}",
        "definition": {
          "entityName": "StudentProfile",
          "description": "Biographical data for students. Locked for students after creation."
        }
      },
      {
        "path": "/admins/{userId}",
        "definition": {
          "description": "Root administrative access markers."
        }
      }
    ]
  }
}