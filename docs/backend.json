
{
  "entities": {
    "College": {
      "title": "College",
      "type": "object",
      "description": "Represents a college or university.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "logoUrl": { "type": "string", "format": "uri" },
        "tagline": { "type": "string" }
      },
      "required": ["id", "name"]
    },
    "User": {
      "title": "User",
      "type": "object",
      "description": "Represents a user (student, faculty, or admin).",
      "properties": {
        "id": { "type": "string" },
        "collegeId": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "firstName": { "type": "string" },
        "lastName": { "type": "string" },
        "role": { "type": "string", "enum": ["student", "faculty", "admin"] },
        "departmentId": { "type": "string" },
        "degreeType": { "type": "string", "enum": ["UG", "PG"] },
        "status": { "type": "string", "enum": ["active", "inactive"] }
      },
      "required": ["id", "collegeId", "email", "role"]
    },
    "Department": {
      "title": "Department",
      "type": "object",
      "description": "Academic department within a college.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "headOfDept": { "type": "string" }
      },
      "required": ["id", "name"]
    },
    "Course": {
      "title": "Course",
      "type": "object",
      "description": "A subject or course offered.",
      "properties": {
        "id": { "type": "string" },
        "code": { "type": "string" },
        "name": { "type": "string" },
        "departmentId": { "type": "string" },
        "credits": { "type": "number" }
      },
      "required": ["id", "code", "name"]
    },
    "Class": {
      "title": "Class",
      "type": "object",
      "description": "A specific section/group of students.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "departmentId": { "type": "string" },
        "facultyId": { "type": "string" }
      },
      "required": ["id", "name"]
    }
  },
  "auth": {
    "providers": ["password", "anonymous"]
  },
  "firestore": {
    "structure": [
      { "path": "/colleges/{collegeId}", "definition": { "entityName": "College" } },
      { "path": "/colleges/{collegeId}/users/{userId}", "definition": { "entityName": "User" } },
      { "path": "/colleges/{collegeId}/departments/{deptId}", "definition": { "entityName": "Department" } },
      { "path": "/colleges/{collegeId}/courses/{courseId}", "definition": { "entityName": "Course" } },
      { "path": "/colleges/{collegeId}/classes/{classId}", "definition": { "entityName": "Class" } }
    ]
  }
}
