
{
  "entities": {
    "Department": {
      "title": "Department",
      "type": "object",
      "description": "An academic division managing courses, faculty, and students.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "headOfDept": { "type": "string" },
        "description": { "type": "string" },
        "programType": { "type": "string", "enum": ["UG", "PG"] },
        "totalSemesters": { "type": "number", "description": "Number of semesters in the program." }
      }
    },
    "Class": {
      "title": "Class (Section)",
      "type": "object",
      "description": "A specific section/batch of students within a department.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "departmentId": { "type": "string" },
        "semester": { "type": "string" },
        "studentIds": { "type": "array", "items": { "type": "string" } },
        "subjectHandlers": { 
          "type": "object", 
          "description": "Map of SubjectID to FacultyID",
          "additionalProperties": { "type": "string" }
        }
      }
    },
    "InstitutionalUser": {
      "title": "InstitutionalUser",
      "type": "object",
      "description": "User profile with role-specific data.",
      "properties": {
        "id": { "type": "string" },
        "role": { "type": "string", "enum": ["student", "faculty", "admin", "hod"] },
        "departmentId": { "type": "string", "description": "Mandatory for HOD, Faculty, and Students." },
        "performanceScore": { "type": "number", "description": "0-100 score based on metrics." },
        "attendanceRate": { "type": "number" }
      }
    },
    "AcademicRecord": {
      "title": "AcademicRecord",
      "type": "object",
      "description": "Stores attendance and marks for a student in a specific class and subject.",
      "properties": {
        "studentId": { "type": "string" },
        "classId": { "type": "string" },
        "subjectId": { "type": "string" },
        "attendance": { "type": "number" },
        "marks": { 
          "type": "object",
          "properties": {
            "cat1": { "type": "number" },
            "cat2": { "type": "number" },
            "final": { "type": "number" }
          }
        }
      }
    },
    "Achievement": {
      "title": "Achievement",
      "type": "object",
      "description": "A recorded academic or extracurricular milestone.",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "year": { "type": "integer" },
        "description": { "type": "string" },
        "category": { "type": "string" },
        "departmentId": { "type": "string" },
        "facultyInCharge": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "Event": {
      "title": "Event",
      "type": "object",
      "description": "A campus activity or seminar.",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "description": { "type": "string" },
        "location": { "type": "string" },
        "category": { "type": "string" },
        "departmentId": { "type": "string" },
        "facultyInCharge": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    }
  },
  "auth": {
    "providers": ["password", "anonymous"]
  },
  "firestore": {
    "structure": [
      {
        "path": "/colleges/{collegeId}/departments/{deptId}",
        "definition": { "entityName": "Department", "description": "Academic divisions." }
      },
      {
        "path": "/colleges/{collegeId}/classes/{classId}",
        "definition": { "entityName": "Class", "description": "Academic sections." }
      },
      {
        "path": "/colleges/{collegeId}/users/{userId}",
        "definition": { "entityName": "InstitutionalUser", "description": "Staff and student directory." }
      },
      {
        "path": "/colleges/{collegeId}/academicRecords/{recordId}",
        "definition": { "entityName": "AcademicRecord", "description": "Aggregated performance data." }
      },
      {
        "path": "/colleges/{collegeId}/achievements/{achievementId}",
        "definition": { "entityName": "Achievement", "description": "Institutional milestones." }
      },
      {
        "path": "/colleges/{collegeId}/events/{eventId}",
        "definition": { "entityName": "Event", "description": "Campus calendar events." }
      }
    ]
  }
}
