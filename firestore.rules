/**
 * Core Philosophy: This ruleset implements a college-centric security model.
 * Public information about a college, such as its achievements, events, and
 * campus photos, is publicly readable by anyone. However, write access to
 * this information is restricted to authorized college staff (users with
 * 'faculty' or 'admin' roles). User profile data is strictly private and
 * can only be accessed or modified by the user who owns it.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    //-------------------------------------------------------------------------
    // Helper Functions
    //-------------------------------------------------------------------------

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    
    function isExistingDoc() {
      return resource != null;
    }

    function isCollegeAdmin(collegeId) {
      return isSignedIn() && get(/databases/$(database)/documents/colleges/$(collegeId)/users/$(request.auth.uid)).data.role == 'admin';
    }

    function isCollegeStaff(collegeId) {
      return isSignedIn() && get(/databases/$(database)/documents/colleges/$(collegeId)/users/$(request.auth.uid)).data.role in ['faculty', 'admin'];
    }

    function incomingData() {
      return request.resource.data;
    }

    function existingData() {
      return resource.data;
    }

    //-------------------------------------------------------------------------
    // Collection Rules
    //-------------------------------------------------------------------------

    match /colleges/{collegeId} {
      allow get, list: if true;
      allow create, update, delete: if false;

      match /achievements/{achievementId} {
        allow get, list: if true;
        allow create, update, delete: if isCollegeStaff(collegeId);
      }

      match /campus_images/{imageId} {
        allow get, list: if true;
        allow create, update, delete: if isCollegeStaff(collegeId);
      }
      
      match /events/{eventId} {
        allow get, list: if true;
        allow create, update, delete: if isCollegeStaff(collegeId);
      }
      
      match /users/{userId} {
        allow get: if isOwner(userId) || isCollegeAdmin(collegeId);
        allow list: if isCollegeAdmin(collegeId);
        allow create: if isOwner(userId) || isCollegeAdmin(collegeId);
        allow update: if (isOwner(userId) && incomingData().role == existingData().role) || isCollegeAdmin(collegeId);
        allow delete: if isCollegeAdmin(collegeId);
      }
    }
  }
}