rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * COLLEGE DATA MANAGEMENT SYSTEM - SECURITY RULES
     * 
     * CORE PHILOSOPHY:
     * This ruleset implements a Role-Based Access Control (RBAC) model combined with individual 
     * ownership for sensitive data. It prioritizes "Authorization Independence" by using 
     * marker collections for roles and denormalized fields (like 'userId') for ownership checks, 
     * ensuring high performance and clear audit trails.
     * 
     * DATA STRUCTURE:
     * - /collegeInfo, /achievements, /galleryImages, /events: Publicly readable singleton or collections.
     * - /studentProfiles: Sensitive biographical data. Access is restricted to the student owner, 
     *   faculty members, and administrators.
     * - /roles_admin, /roles_faculty: Internal marker collections to identify privileged users.
     * 
     * KEY SECURITY DECISIONS:
     * 1. Public Access: General college information is readable by any user (including anonymous/unauthenticated).
     * 2. Administrative Control: All write operations on public data are restricted to accounts 
     *    verified in the 'roles_admin' collection.
     * 3. Student Bio-Data: Students can create their own profiles, but once created, updates are 
     *    strictly locked to Administrators only to ensure data integrity for official records.
     * 4. Relational Integrity: On creation of a profile, the rules enforce that the 'userId' 
     *    field matches the student's authenticated UID to prevent identity spoofing.
     */

    // --- Helper Functions ---

    /** Checks if a user is authenticated with any provider. */
    function isSignedIn() {
      return request.auth != null;
    }

    /** Checks if the authenticated user has the Admin role. */
    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    /** Checks if the authenticated user has the Faculty role. */
    function isFaculty() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_faculty/$(request.auth.uid));
    }

    /** Checks if the user's UID matches a specific target ID. */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- Collection Rules ---

    /**
     * @description Public college information.
     * @path /collegeInfo/main
     * @allow get (any user), create/update (admin)
     * @deny write (non-admin)
     * @principle Public read with admin-only writes.
     */
    match /collegeInfo/{document} {
      allow get, list: if true;
      allow create, update, delete: if isAdmin();
    }

    /**
     * @description Highlights of college achievements.
     * @path /achievements/{achievementId}
     * @allow get (any user), create/update/delete (admin)
     * @deny write (non-admin)
     * @principle Public read with admin-only writes.
     */
    match /achievements/{achievementId} {
      allow get, list: if true;
      allow create, update, delete: if isAdmin();
    }

    /**
     * @description Gallery metadata for campus images.
     * @path /galleryImages/{galleryImageId}
     * @allow get (any user), create/update/delete (admin)
     * @deny write (non-admin)
     * @principle Public read with admin-only writes.
     */
    match /galleryImages/{galleryImageId} {
      allow get, list: if true;
      allow create, update, delete: if isAdmin();
    }

    /**
     * @description College event schedules and details.
     * @path /events/{eventId}
     * @allow get (any user), create/update/delete (admin)
     * @deny write (non-admin)
     * @principle Public read with admin-only writes.
     */
    match /events/{eventId} {
      allow get, list: if true;
      allow create, update, delete: if isAdmin();
    }

    /**
     * @description Sensitive student biographical data.
     * @path /studentProfiles/{studentProfileId}
     * @allow get/list (owner, faculty, admin), create (owner, admin), update (admin)
     * @deny update (student owner), list (anonymous)
     * @principle Restricted access based on ownership or role; immutable for students after creation.
     */
    match /studentProfiles/{studentProfileId} {
      // Students can read their own data; Faculty and Admins can read all.
      allow get, list: if isAdmin() || isFaculty() || (resource != null && isOwner(resource.data.userId));
      
      // Allow student to create their own record OR an admin to create one.
      allow create: if isAdmin() || (isSignedIn() && request.resource.data.userId == request.auth.uid);
      
      // Updates and deletes are restricted to Admins only.
      allow update, delete: if isAdmin() && resource != null;
    }

    /**
     * @description Administrative role markers.
     * @path /roles_admin/{adminId}
     * @allow get (signed-in), list (admin)
     * @deny write (client-side)
     * @principle Marker collection for authorization verification.
     */
    match /roles_admin/{adminId} {
      allow get: if isSignedIn();
      allow list: if isAdmin();
      allow create, update, delete: if false; // Managed via Admin SDK or Console
    }

    /**
     * @description Faculty role markers.
     * @path /roles_faculty/{facultyId}
     * @allow get (signed-in), list (admin/faculty)
     * @deny write (client-side)
     * @principle Marker collection for authorization verification.
     */
    match /roles_faculty/{facultyId} {
      allow get: if isSignedIn();
      allow list: if isAdmin() || isFaculty();
      allow create, update, delete: if false; // Managed via Admin SDK or Console
    }
  }
}