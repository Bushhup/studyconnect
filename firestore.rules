rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * STUDYCONNECT SECURITY RULES
     * 
     * Handles role-based access for both top-level and nested institutional collections.
     */

    // --- Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    /** 
     * Admin check: Verified via marker collections or root admins collection.
     */
    function isAdmin() {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid)) ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
    }

    /**
     * Faculty check: Verified via marker collection.
     */
    function isFaculty() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_faculty/$(request.auth.uid));
    }

    /** 
     * Owner check: Matches UID.
     */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- Public Content Rules ---

    match /collegeInfo/{doc} { allow read: if true; allow write: if isAdmin(); }
    match /achievements/{doc} { allow read: if true; allow write: if isAdmin(); }
    match /galleryImages/{doc} { allow read: if true; allow write: if isAdmin(); }
    match /events/{doc} { allow read: if true; allow write: if isAdmin(); }

    // --- Institutional Hierarchy ---

    match /colleges/{collegeId} {
      allow get: if true;
      
      // User Directory: Allow lookup by username for login, full access for Admin
      match /users/{userId} {
        allow get: if isSignedIn();
        allow list: if isAdmin() || (isSignedIn() && request.query.limit <= 1);
        allow write: if isAdmin();
      }

      match /departments/{id} { allow read: if true; allow write: if isAdmin(); }
      match /classes/{id} { allow read: if true; allow write: if isAdmin(); }
      match /courses/{id} { allow read: if true; allow write: if isAdmin(); }
      match /achievements/{id} { allow read: if true; allow write: if isAdmin(); }
      match /events/{id} { allow read: if true; allow write: if isAdmin(); }

      /**
       * Student Bio Data: 
       * - Readable by Owner, Faculty, and Admin.
       * - Creatable by Owner (once).
       * - Updatable ONLY by Admin.
       */
      match /studentProfiles/{profileId} {
        allow get, list: if isAdmin() || isFaculty() || (isSignedIn() && resource != null && resource.data.userId == request.auth.uid);
        allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
        allow update, delete: if isAdmin();
      }
    }

    // --- Auth & Role Markers ---

    match /roles_admin/{id} { allow get: if isSignedIn(); allow list: if isAdmin(); }
    match /roles_faculty/{id} { allow get: if isSignedIn(); allow list: if isAdmin() || isFaculty(); }
    match /admins/{id} { allow get, write: if true; } // Facilitates initial admin setup
  }
}