rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * STUDYCONNECT SECURITY RULES
     * Implements "Bootstrap Loophole" and robust role-based access.
     */

    function isSignedIn() {
      return request.auth != null;
    }

    function getUserData() {
      let email = request.auth.token.email;
      let path = /databases/$(database)/documents/colleges/study-connect-college/users/$(email);
      return exists(path) ? get(path).data : null;
    }

    function isAdmin() {
      let email = request.auth.token.email;
      return isSignedIn() && (
        email == 'admin@college.edu' ||
        email == 'shabu@gmail.com' ||
        (getUserData() != null && getUserData().role == 'admin')
      );
    }
    
    function isHOD() {
      return isSignedIn() && getUserData() != null && getUserData().role == 'hod';
    }

    function isSystemUninitialized() {
      // Allows bootstrap if the master admin record is missing
      return !exists(/databases/$(database)/documents/colleges/study-connect-college/users/shabu@gmail.com) &&
             !exists(/databases/$(database)/documents/colleges/study-connect-college/users/admin@college.edu);
    }

    match /colleges/{collegeId} {
      // Allow read for everyone to see the college name/tagline on home page
      allow get: if true;
      // Allow write during bootstrap or if user is admin
      allow write, update: if isSystemUninitialized() || isAdmin();

      match /users/{userId} {
        allow get: if true; 
        allow list: if isAdmin() || (isSignedIn() && getUserData() != null && getUserData().role in ['faculty', 'hod']);
        // Allow creation of records during bootstrap or by an existing admin
        allow create, update, delete: if isSystemUninitialized() || isAdmin();
      }

      match /departments/{id} { 
        allow read: if true; 
        // Allow admin or HOD to manage department metadata
        allow write, update: if isSystemUninitialized() || isAdmin() || isHOD(); 
      }
      
      match /classes/{id} { 
        allow read: if true; 
        allow write, update: if isSystemUninitialized() || isAdmin() || (isSignedIn() && getUserData() != null && getUserData().role in ['faculty', 'hod']); 
      }
      
      match /courses/{id} { 
        allow read: if true; 
        allow write, update: if isSystemUninitialized() || isAdmin(); 
      }
      
      match /academicRecords/{id} {
        allow read: if isSignedIn();
        allow write, update: if isSystemUninitialized() || isAdmin() || (isSignedIn() && getUserData() != null && getUserData().role in ['faculty', 'hod']);
      }

      match /studentProfiles/{userId} { 
        allow read: if isSignedIn(); 
        allow write, update: if isSystemUninitialized() || isAdmin() || (isSignedIn() && request.auth.token.email == userId); 
      }
      
      match /facultyProfiles/{userId} { 
        allow read: if isSignedIn(); 
        allow write, update: if isSystemUninitialized() || isAdmin() || (isSignedIn() && request.auth.token.email == userId); 
      }

      match /achievements/{id} { 
        allow read: if true; 
        allow write, update: if isSystemUninitialized() || isAdmin(); 
      }
      
      match /events/{id} { 
        allow read: if true; 
        allow write, update: if isSystemUninitialized() || isAdmin(); 
      }
    }
  }
}