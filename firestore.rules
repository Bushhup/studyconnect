
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * STUDYCONNECT SECURITY RULES
     * 
     * Handles role-based access for institutional content and data.
     */

    // --- Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/colleges/study-connect-college/users/$(request.auth.uid)).data;
    }

    function isAdmin() {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) ||
        getUserData().role == 'admin'
      );
    }

    function isHOD() {
      return isSignedIn() && getUserData().role == 'hod';
    }

    function hodDept() {
      return getUserData().departmentId;
    }

    function isFaculty() {
      return isSignedIn() && getUserData().role == 'faculty';
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- Institutional Content Rules ---

    match /colleges/{collegeId} {
      allow get: if true;
      
      // Global College Info: Only Master Admin
      allow update: if isAdmin();

      match /users/{userId} {
        allow get: if isSignedIn();
        allow list: if true;
        allow write: if isAdmin() || (isHOD() && userId == request.auth.uid);
      }

      match /departments/{id} { 
        allow read: if true; 
        allow write: if isAdmin() || (isHOD() && id == hodDept()); 
      }
      
      match /classes/{id} { 
        allow read: if true; 
        allow write: if isAdmin() || (isHOD() && get(/databases/$(database)/documents/colleges/$(collegeId)/classes/$(id)).data.departmentId == hodDept()); 
      }
      
      match /courses/{id} { 
        allow read: if true; 
        allow write: if isAdmin() || (isHOD() && get(/databases/$(database)/documents/colleges/$(collegeId)/courses/$(id)).data.departmentId == hodDept()); 
      }
      
      /**
       * Academic Records: 
       * - Admins, HODs, and Faculty can read all records for analytics.
       * - Students can read their own records.
       * - Only staff roles can write.
       */
      match /academicRecords/{id} {
        allow read: if isAdmin() || isHOD() || isFaculty() || (isSignedIn() && resource.data.studentId == request.auth.uid);
        allow write: if isAdmin() || isHOD() || isFaculty();
      }

      /**
       * Achievements & Events: 
       * - Publicly readable.
       * - Editable by Admin.
       * - Editable by HOD if they belong to the HOD's department.
       */
      match /achievements/{id} { 
        allow read: if true; 
        allow create: if isAdmin() || isHOD();
        allow update, delete: if isAdmin() || (isHOD() && resource.data.departmentId == hodDept()); 
      }

      match /events/{id} { 
        allow read: if true; 
        allow create: if isAdmin() || isHOD();
        allow update, delete: if isAdmin() || (isHOD() && resource.data.departmentId == hodDept()); 
      }

      match /studentProfiles/{userId} {
        allow get: if isOwner(userId) || isAdmin() || isFaculty() || isHOD();
        allow list: if isAdmin() || isFaculty() || isHOD();
        allow create: if isOwner(userId);
        allow update, delete: if isAdmin();
      }
    }

    // --- Role Markers ---
    match /admins/{id} { allow get, write: if true; }
  }
}
