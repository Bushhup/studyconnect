rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * STUDYCONNECT SECURITY RULES
     * Breaks recursion by allowing bootstrap and simple email-based role checks.
     */

    function isSignedIn() {
      return request.auth != null;
    }

    function getUserRole(email) {
      let path = /databases/$(database)/documents/colleges/study-connect-college/users/$(email.lower());
      return exists(path) ? get(path).data.role : null;
    }

    function isAdmin() {
      return isSignedIn() && (
        getUserRole(request.auth.token.email) == 'admin'
      );
    }

    match /colleges/{collegeId} {
      allow get: if true;
      // Allow initial seeding if the database is empty or user is admin
      allow update, write: if isAdmin() || !exists(/databases/$(database)/documents/colleges/$(collegeId)/users/admin@college.edu);

      match /users/{userId} {
        allow get: if isSignedIn();
        allow list: if isAdmin() || getUserRole(request.auth.token.email) in ['faculty', 'hod'];
        allow create, update, delete: if isAdmin() || !exists(/databases/$(database)/documents/colleges/$(collegeId)/users/admin@college.edu);
      }

      match /departments/{id} { 
        allow read: if true; 
        allow write: if isAdmin(); 
      }
      
      match /classes/{id} { 
        allow read: if true; 
        allow write: if isAdmin() || getUserRole(request.auth.token.email) in ['faculty', 'hod']; 
      }
      
      match /courses/{id} { 
        allow read: if true; 
        allow write: if isAdmin(); 
      }
      
      match /academicRecords/{id} {
        allow read: if isSignedIn();
        allow write: if isAdmin() || getUserRole(request.auth.token.email) in ['faculty', 'hod'];
      }

      match /studentProfiles/{userId} { 
        allow read: if isSignedIn(); 
        allow write: if isAdmin() || (isSignedIn() && request.auth.token.email.lower() == userId.lower()); 
      }
      
      match /facultyProfiles/{userId} { 
        allow read: if isSignedIn(); 
        allow write: if isAdmin() || (isSignedIn() && request.auth.token.email.lower() == userId.lower()); 
      }

      match /achievements/{id} { allow read: if true; allow write: if isAdmin(); }
      match /events/{id} { allow read: if true; allow write: if isAdmin(); }
    }
  }
}
