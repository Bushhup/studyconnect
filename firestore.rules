rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * STUDYCONNECT SECURITY RULES
     * Implements "Bootstrap Loophole" to allow initial setup.
     */

    function isSignedIn() {
      return request.auth != null;
    }

    function getUserRole() {
      // Safely check role if user is signed in and has an email token
      return (isSignedIn() && "email" in request.auth.token) 
        ? get(/databases/$(database)/documents/colleges/study-connect-college/users/$(request.auth.token.email.lower())).data.role 
        : null;
    }

    function isAdmin() {
      return isSignedIn() && getUserRole() == 'admin';
    }

    function isSystemUninitialized() {
      // Allows bootstrap if the master admin record is missing
      return !exists(/databases/$(database)/documents/colleges/study-connect-college/users/shabu@gmail.com) &&
             !exists(/databases/$(database)/documents/colleges/study-connect-college/users/admin@college.edu);
    }

    match /colleges/{collegeId} {
      // Allow read for everyone to see the college name/tagline on home page
      allow get: if true;
      // Allow write during bootstrap or if user is admin
      allow write, update: if isSystemUninitialized() || isAdmin();

      match /users/{userId} {
        allow get: if true; 
        allow list: if isAdmin() || (isSignedIn() && getUserRole() in ['faculty', 'hod']);
        // Allow creation of records during bootstrap or by an existing admin
        allow create, update, delete: if isSystemUninitialized() || isAdmin();
      }

      match /departments/{id} { 
        allow read: if true; 
        allow write: if isSystemUninitialized() || isAdmin(); 
      }
      
      match /classes/{id} { 
        allow read: if true; 
        allow write: if isSystemUninitialized() || isAdmin() || (isSignedIn() && getUserRole() in ['faculty', 'hod']); 
      }
      
      match /courses/{id} { 
        allow read: if true; 
        allow write: if isSystemUninitialized() || isAdmin(); 
      }
      
      match /academicRecords/{id} {
        allow read: if isSignedIn();
        allow write: if isSystemUninitialized() || isAdmin() || (isSignedIn() && getUserRole() in ['faculty', 'hod']);
      }

      match /studentProfiles/{userId} { 
        allow read: if isSignedIn(); 
        allow write: if isSystemUninitialized() || isAdmin() || (isSignedIn() && request.auth.token.email.lower() == userId.lower()); 
      }
      
      match /facultyProfiles/{userId} { 
        allow read: if isSignedIn(); 
        allow write: if isSystemUninitialized() || isAdmin() || (isSignedIn() && request.auth.token.email.lower() == userId.lower()); 
      }

      match /achievements/{id} { 
        allow read: if true; 
        allow write: if isSystemUninitialized() || isAdmin(); 
      }
      
      match /events/{id} { 
        allow read: if true; 
        allow write: if isSystemUninitialized() || isAdmin(); 
      }
    }
  }
}