rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * SHIELD FIREBASE SECURITY RULES
     * 
     * Core Philosophy:
     * This ruleset implements a centralized administrative control model for a college information portal. 
     * Content is intended for broad public consumption (events, achievements) or authenticated 
     * institutional access (departments, classes), while modification is strictly restricted 
     * to verified administrators.
     *
     * Data Structure:
     * - Public Content: /colleges/{id}/events, /colleges/{id}/achievements are globally readable.
     * - Institutional Content: /colleges/{id}/departments, /colleges/{id}/classes require auth.
     * - Admin Management: A dedicated /admins collection stores UIDs of users with write privileges.
     * - User Profiles: Users can manage their own profile; admins have full directory access.
     */

    // --- Helper Functions ---

    /** @description Checks if the user is authenticated with Firebase Auth. */
    function isSignedIn() {
      return request.auth != null;
    }

    /** @description Validates if the authenticated user's UID matches the provided userId. */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /** @description Checks if the authenticated user exists in the designated global admins collection. */
    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    /** @description Combines admin check with existence check for destructive/modifying operations. */
    function isAuthorizedAdmin() {
      return isAdmin() && (resource != null || request.method == 'create');
    }

    // --- Collection Rules ---

    /**
     * @description Institutional Root and Sub-collections
     * @path /colleges/{collegeId}
     */
    match /colleges/{collegeId} {
      allow get: if true;
      allow write: if isAdmin();

      /**
       * @description Institutional directory of students, faculty, and admins.
       */
      match /users/{userId} {
        allow get: if isSignedIn();
        allow list: if isAdmin();
        allow create, update: if isAdmin() || isOwner(userId);
        allow delete: if isAdmin();
      }

      /**
       * @description Academic departments and divisions.
       */
      match /departments/{deptId} {
        allow read: if isSignedIn();
        allow write: if isAdmin();
      }

      /**
       * @description Academic classes and sections.
       */
      match /classes/{classId} {
        allow read: if isSignedIn();
        allow write: if isAdmin();
      }

      /**
       * @description College event calendar data (nested).
       */
      match /events/{eventId} {
        allow read: if true;
        allow write: if isAdmin();
      }

      /**
       * @description Academic achievements (nested).
       */
      match /achievements/{achievementId} {
        allow read: if true;
        allow write: if isAdmin();
      }
    }

    /**
     * @description Legacy/Alternative paths for public content (if used).
     */
    match /collegeProfile/main {
      allow get, list: if true;
      allow write: if isAdmin();
    }

    match /achievements/{achievementId} {
      allow get, list: if true;
      allow write: if isAdmin();
    }

    match /events/{eventId} {
      allow get, list: if true;
      allow write: if isAdmin();
    }

    /**
     * @description The root of authority. Stores UIDs of users with administrative privileges.
     * @path /admins/{adminId}
     */
    match /admins/{adminId} {
      allow get: if isOwner(adminId) || isAdmin();
      allow list: if isAdmin();
      allow create: if (isAdmin() && adminId == request.resource.data.id) || (request.auth.uid != null && request.resource.data.id == request.auth.uid && !exists(/databases/$(database)/documents/admins/initial_setup_token));
      allow update: if isAuthorizedAdmin();
      allow delete: if isAuthorizedAdmin();
    }
  }
}
