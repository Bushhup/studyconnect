rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * STUDYCONNECT SECURITY RULES - ADMIN RESTRICTED ACCESS
     * 
     * Handles role-based access for institutional content and data.
     * Creation and deletion of users is restricted to Admins.
     */

    // --- Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    // Safely retrieves the user's directory record by checking the standard collegeId
    function getUserData() {
      let email = request.auth.token.email;
      let path = /databases/$(database)/documents/colleges/study-connect-college/users/$(email);
      return (email != null && exists(path)) ? get(path).data : null;
    }

    function isAdmin() {
      let data = getUserData();
      return isSignedIn() && (
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) ||
        (data != null && data.role == 'admin')
      );
    }

    function isHOD() {
      let data = getUserData();
      return isSignedIn() && data != null && data.role == 'hod';
    }

    function hodDept() {
      let data = getUserData();
      return data != null ? data.departmentId : null;
    }

    function isFaculty() {
      let data = getUserData();
      return isSignedIn() && data != null && data.role == 'faculty';
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- Institutional Content Rules ---

    match /colleges/{collegeId} {
      allow get: if true;
      allow update: if isAdmin();

      match /users/{userId} {
        // Only Admins can CREATE or DELETE users to control portal access
        allow create, delete: if isAdmin();
        
        // Signed in users can look up their own profile or other profiles if they are faculty/admin
        allow get: if isSignedIn();
        allow list: if isAdmin() || isFaculty() || isHOD();
        
        // Users can update their own non-critical profile fields
        allow update: if isAdmin() || (isSignedIn() && request.auth.token.email == userId);
      }

      match /departments/{id} { 
        allow read: if true; 
        allow write: if isAdmin() || (isHOD() && id == hodDept()); 
      }
      
      match /classes/{id} { 
        allow read: if true; 
        allow write: if isAdmin() || (isHOD() && hodDept() != null && get(/databases/$(database)/documents/colleges/$(collegeId)/classes/$(id)).data.departmentId == hodDept()); 
      }
      
      match /courses/{id} { 
        allow read: if true; 
        allow write: if isAdmin() || (isHOD() && hodDept() != null && get(/databases/$(database)/documents/colleges/$(collegeId)/courses/$(id)).data.departmentId == hodDept()); 
      }
      
      match /academicRecords/{id} {
        allow list: if isSignedIn() && (isAdmin() || isHOD() || isFaculty());
        allow get: if isAdmin() || isHOD() || isFaculty() || (isSignedIn() && resource.data.studentId == request.auth.uid);
        allow write: if isAdmin() || isHOD() || isFaculty();
      }

      match /achievements/{id} { 
        allow read: if true; 
        allow create: if isAdmin() || isHOD();
        allow update, delete: if isAdmin() || (isHOD() && resource.data.departmentId == hodDept()); 
      }

      match /events/{id} { 
        allow read: if true; 
        allow create: if isAdmin() || isHOD();
        allow update, delete: if isAdmin() || (isHOD() && resource.data.departmentId == hodDept()); 
      }

      match /studentProfiles/{userId} {
        allow get: if isOwner(userId) || isAdmin() || isFaculty() || isHOD();
        allow list: if isAdmin() || isFaculty() || isHOD();
        allow create: if isOwner(userId) || isAdmin();
        allow update, delete: if isAdmin();
      }

      match /facultyProfiles/{userId} {
        allow get: if isOwner(userId) || isAdmin() || isHOD();
        allow list: if isAdmin() || isHOD();
        allow write: if isOwner(userId) || isAdmin();
      }
    }

    // --- Role Markers ---
    match /admins/{id} { 
      allow get: if isSignedIn();
      allow write: if isSignedIn() && (request.auth.uid == id || isAdmin()); 
    }
  }
}