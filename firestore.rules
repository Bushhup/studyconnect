
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * STUDYCONNECT SECURITY RULES
     * 
     * Handles role-based access for institutional content and data.
     * Uses email-based document IDs for directory lookup during login.
     */

    // --- Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    function getUserData() {
      // We look up users by their email in the institutional directory
      let email = request.auth.token.email;
      if (email == null) { return null; }
      
      let path = /databases/$(database)/documents/colleges/study-connect-college/users/$(email);
      return exists(path) ? get(path).data : null;
    }

    function isAdmin() {
      let data = getUserData();
      return isSignedIn() && (
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) ||
        (data != null && data.role == 'admin')
      );
    }

    function isHOD() {
      let data = getUserData();
      return isSignedIn() && data != null && data.role == 'hod';
    }

    function hodDept() {
      let data = getUserData();
      return data != null ? data.departmentId : null;
    }

    function isFaculty() {
      let data = getUserData();
      return isSignedIn() && data != null && data.role == 'faculty';
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- Institutional Content Rules ---

    match /colleges/{collegeId} {
      allow get: if true;
      
      // Global College Info: Only Master Admin
      allow update: if isAdmin();

      match /users/{userId} {
        // userId here is the email address
        allow get: if isSignedIn();
        allow list: if isSignedIn(); 
        allow write: if isAdmin() || (isSignedIn() && request.auth.token.email == userId);
      }

      match /departments/{id} { 
        allow read: if true; 
        allow write: if isAdmin() || (isHOD() && id == hodDept()); 
      }
      
      match /classes/{id} { 
        allow read: if true; 
        allow write: if isAdmin() || (isHOD() && hodDept() != null && exists(/databases/$(database)/documents/colleges/$(collegeId)/classes/$(id)) && get(/databases/$(database)/documents/colleges/$(collegeId)/classes/$(id)).data.departmentId == hodDept()); 
      }
      
      match /courses/{id} { 
        allow read: if true; 
        allow write: if isAdmin() || (isHOD() && hodDept() != null && exists(/databases/$(database)/documents/colleges/$(collegeId)/courses/$(id)) && get(/databases/$(database)/documents/colleges/$(collegeId)/courses/$(id)).data.departmentId == hodDept()); 
      }
      
      match /academicRecords/{id} {
        allow list: if isSignedIn() && (isAdmin() || isHOD() || isFaculty());
        allow get: if isAdmin() || isHOD() || isFaculty() || (isSignedIn() && resource.data.studentId == request.auth.uid);
        allow write: if isAdmin() || isHOD() || isFaculty();
      }

      match /achievements/{id} { 
        allow read: if true; 
        allow create: if isAdmin() || isHOD();
        allow update, delete: if isAdmin() || (isHOD() && resource.data.departmentId == hodDept()); 
      }

      match /events/{id} { 
        allow read: if true; 
        allow create: if isAdmin() || isHOD();
        allow update, delete: if isAdmin() || (isHOD() && resource.data.departmentId == hodDept()); 
      }

      match /studentProfiles/{userId} {
        allow get: if isOwner(userId) || isAdmin() || isFaculty() || isHOD();
        allow list: if isAdmin() || isFaculty() || isHOD();
        allow create: if isOwner(userId);
        allow update, delete: if isAdmin();
      }

      match /facultyProfiles/{userId} {
        allow get: if isOwner(userId) || isAdmin() || isHOD();
        allow list: if isAdmin() || isHOD();
        allow write: if isOwner(userId) || isAdmin();
      }
    }

    // --- Role Markers ---
    match /admins/{id} { allow get, write: if true; }
  }
}
